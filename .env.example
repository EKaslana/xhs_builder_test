# Builder Demo Coach — environment variables
#
# By default the app runs entirely in Mock mode (no API calls, fully
# reproducible). Set the variables below to switch the three core entry points
# (idea summary, guided Q&A, step generation) to a real OpenAI-compatible LLM.
# Any failure (timeout, 429, 5xx, malformed JSON) automatically falls back to
# the Mock implementation, so the app keeps running even if the provider is
# down.

# Master switch. Required to be "1" before any real call is made.
USE_REAL_LLM=1

# API key for the chosen provider. Required when USE_REAL_LLM=1.
LLM_API_KEY=sk-replace-me

# Provider hint. Optional — auto-detected from LLM_BASE_URL if omitted.
# One of: perplexity | deepseek | openai | custom
LLM_PROVIDER=perplexity

# Model name passed to the OpenAI-compatible /chat/completions endpoint.
# Examples:
#   Perplexity : sonar | sonar-pro | sonar-reasoning
#   DeepSeek   : deepseek-chat | deepseek-reasoner
#   OpenAI     : gpt-4o-mini | gpt-4o
LLM_MODEL=sonar-pro

# Base URL of the OpenAI-compatible endpoint (no trailing /chat/completions).
#   Perplexity : https://api.perplexity.ai
#   DeepSeek   : https://api.deepseek.com
#   OpenAI     : https://api.openai.com/v1
LLM_BASE_URL=https://api.perplexity.ai

# Optional tuning.
LLM_TEMPERATURE=0.4
LLM_TIMEOUT_MS=25000
LLM_MAX_RETRIES=2
# LLM_SEED=42
